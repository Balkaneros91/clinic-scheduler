// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum AppRole {
  ADMIN
  EMPLOYEE
}

enum AbsenceStatus {
  PENDING
  APPROVED
  REJECTED
}

model Employee {
  id        String  @id @default(cuid())
  firstName String
  lastName  String
  isActive  Boolean @default(true)

  authUserId String?  @unique
  appRole    AppRole  @default(EMPLOYEE)

  roleId String
  role   Role   @relation(fields: [roleId], references: [id])

  employmentTypeId String
  employmentType   EmploymentType @relation(fields: [employmentTypeId], references: [id])

  responsibilities EmployeeResponsibility[]
  schedules        ScheduleAssignment[]
  absences         Absence[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Role {
  id   String @id @default(cuid())
  name String @unique

  employees Employee[]
}

model EmploymentType {
  id   String @id @default(cuid())
  name String @unique

  employees Employee[]
}

model Responsibility {
  id   String @id @default(cuid())
  name String @unique

  employeeResponsibilities EmployeeResponsibility[]
}

model EmployeeResponsibility {
  employeeId       String
  responsibilityId String

  employee       Employee       @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  responsibility Responsibility @relation(fields: [responsibilityId], references: [id], onDelete: Cascade)

  proficiency Int @default(3)

  @@id([employeeId, responsibilityId])
}

model Department {
  id   String @id @default(cuid())
  name String @unique

  schedules ScheduleAssignment[]
}

model ShiftTemplate {
  id        String  @id @default(cuid())
  name      String  @unique
  startTime String
  endTime   String
  isBreak   Boolean @default(false)

  schedules ScheduleAssignment[]
}

model Schedule {
  id    String @id @default(cuid())
  name  String
  year  Int
  month Int

  assignments ScheduleAssignment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([year, month])
}

model ScheduleAssignment {
  id   String   @id @default(cuid())
  date DateTime

  scheduleId String
  schedule   Schedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)

  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id])

  departmentId String
  department   Department @relation(fields: [departmentId], references: [id])

  shiftId String
  shift   ShiftTemplate @relation(fields: [shiftId], references: [id])

  notes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Absence {
  id        String   @id @default(cuid())
  startDate DateTime
  endDate   DateTime?
  notes     String?

  status    AbsenceStatus @default(PENDING)

  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id])

  absenceTypeId String
  absenceType   AbsenceType @relation(fields: [absenceTypeId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AbsenceType {
  id   String @id @default(cuid())
  name String @unique

  absences Absence[]
}
